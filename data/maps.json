      {"id": "to_wild_a", "target_map": "wild_a_sunny_path", "spawn_pos": [800, 300]},
      {"id": "to_town", "target_map": "small_town", "spawn_pos": [100, 300]}
    ],
    "safe_point": [400, 300]
  },
  "small_town": {
    "name": "小城镇",
    "scene": "res://scenes/maps/small_town.tscn",
